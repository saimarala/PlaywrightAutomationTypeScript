pipeline {

    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/your-repo/playwright-e2e.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t playwright-test .'
            }
        }

        stage('Run Kubernetes Job') {
            steps {
                sh 'kubectl apply -f k8s-deployment.yaml'
            }
        }

        stage('Check Pods') {
            steps {
                sh 'kubectl get pods'
            }
        }

    }

}